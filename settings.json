{
  "model": "claude-sonnet-4-6",
  "language": "french",
  "companyAnnouncements": [
    "⚡ TechTown — Expertise IA & Cloud | techtown.fr"
  ],
  "includeGitInstructions": true,
  "cleanupPeriodDays": 30,
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Read",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git branch *)",
      "Bash(git pull *)",
      "Bash(git fetch *)",
      "Bash(git push)",
      "Bash(git push origin *)",
      "Bash(bun run *)",
      "Bash(bun test *)",
      "Bash(bun install)",
      "Bash(npm run *)",
      "Bash(npm test *)",
      "Bash(npm ci)",
      "Bash(npx *)",
      "Bash(gcloud *)",
      "Bash(gsutil *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(pwd)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(./secrets/**)",
      "Read(**/secrets/**)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.gnupg/**)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(~/.ssh/**)",
      "Edit(~/.aws/**)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -fdx*)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf /*)",
      "Bash(sudo *)",
      "Bash(dd if=*of=/dev/*)",
      "Bash(mkfs*)",
      "Bash(curl *| sh*)",
      "Bash(curl *|sh*)",
      "Bash(wget *| sh*)",
      "Bash(wget *|sh*)"
    ]
  },
  "attribution": {
    "commit": "Co-authored-by: Claude Code (TechTown) <ai@techtown.fr>"
  }
}
