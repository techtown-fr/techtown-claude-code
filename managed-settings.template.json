{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "forceRemoteSettingsRefresh": false,
  "requiredMinimumVersion": "2.1.169",
  "forceLoginOrgUUID": "6d572fd6-b704-47b1-9bc8-1a9847128db7",
  "model": "claude-sonnet-4-6",
  "language": "french",
  "includeGitInstructions": true,
  "cleanupPeriodDays": 60,
  "companyAnnouncements": [
    "🤖 Avec grand pouvoir vient grande responsabilité"
  ],
  "attribution": {
    "commit": "Co-authored-by: Claude Code (TechTown)",
    "pr": "Co-authored-by: Claude Code (TechTown)"
  },
  "allowManagedMcpServersOnly": true,
  "allowedMcpServers": [
    { "serverName": "github" },
    { "serverName": "context7" },
    { "serverName": "playwright" }
  ],
  "strictKnownMarketplaces": [
    { "source": "github", "repo": "anthropics/claude-plugins-official" },
    { "source": "github", "repo": "anthropics/claude-plugins-community" },
    { "source": "github", "repo": "techtown-fr/techtown-marketplace" }
  ],
  "extraKnownMarketplaces": {
    "techtown-marketplace": {
      "source": { "source": "github", "repo": "techtown-fr/techtown-marketplace" }
    }
  },
  "enabledPlugins": {
    "techtown-guardrails@techtown-marketplace": true
  },
  "permissions": {
    "disableBypassPermissionsMode": "disable",
    "allow": [
      "Bash(gcloud * list:*)",
      "Bash(gcloud * describe:*)",
      "Bash(gcloud * get-iam-policy:*)",
      "Bash(gcloud config list:*)",
      "Bash(gcloud config get-value:*)",
      "Bash(gcloud info:*)",
      "Bash(gcloud version)",
      "Bash(gcloud auth list:*)",
      "Bash(gcloud storage ls:*)",
      "Bash(gsutil ls:*)",
      "Bash(gsutil stat:*)",
      "Bash(bq ls:*)",
      "Bash(bq show:*)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(./secrets/**)",
      "Read(**/secrets/**)",
      "Read(~/.ssh/**)",
      "Read(~/.config/gcloud/**)",
      "Read(~/.aws/**)",
      "Read(~/.gnupg/**)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(~/.ssh/**)",
      "Bash(curl *|sh)",
      "Bash(wget *|sh)"
    ],
    "ask": [
      "Bash(rm -rf /:*)",
      "Bash(rm -rf ~:*)",
      "Bash(sudo rm -rf /:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push origin --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fdx:*)",
      "Bash(gcloud * delete *)",
      "Bash(gcloud projects delete:*)",
      "Bash(gcloud * add-iam-policy-binding *)",
      "Bash(gcloud * remove-iam-policy-binding *)",
      "Bash(gcloud * set-iam-policy *)",
      "Bash(gcloud services disable *)",
      "Bash(gcloud storage rm *)",
      "Bash(gcloud auth revoke *)",
      "Bash(gsutil rm:*)",
      "Bash(bq rm:*)",
      "Bash(terraform apply:*)",
      "Bash(terraform destroy:*)",
      "Bash(gh repo delete:*)",
      "Bash(gh repo edit --visibility public:*)",
      "Bash(dd if=*of=/dev/*)",
      "Bash(mkfs:*)",
      "Bash(diskutil eraseDisk:*)"
    ]
  }
}
